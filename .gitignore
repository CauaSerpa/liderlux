# CODEIGNITER LOGS & CACHE
# =========================
/application/logs/*
!/application/logs/index.html

/application/cache/*
!/application/cache/index.html

# =========================
# UPLOADS (SE FOR LOCAL)
/uploads/*
!/uploads/index.html

