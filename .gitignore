.vscode/
.idea/

# =========================
# DOCKER (opcional mas recomendado)
/docker/data/
/docker/db/data/

# =========================
# TEST / BUILD ARTIFACTS
# =========================
/build/
/dist/

# =========================
# PHP
# =========================
*.log
*.cache
*.sql

